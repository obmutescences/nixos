
animations {
  // Wayfire-ish Burnline (not full-screen)
  // - 只在燃烧前沿附近画火（flameBand），窗口其它区域不额外上色
  // - 开窗：从上到下推进；关窗：从下到上推进
  // - 火舌更丰富：分段火柱 + 多频噪声 + 细节抖动，但避免“大波浪”
  window-open {
    duration-ms 260
    curve "ease-out-expo"
    custom-shader "
    float hash21(vec2 p){
      p = fract(p * vec2(123.34, 456.21));
      p += dot(p, p + 45.32);
      return fract(p.x * p.y);
    }
    float noise(vec2 p){
      vec2 i = floor(p);
      vec2 f = fract(p);
      float a = hash21(i);
      float b = hash21(i + vec2(1.0, 0.0));
      float c = hash21(i + vec2(0.0, 1.0));
      float d = hash21(i + vec2(1.0, 1.0));
      vec2 u = f*f*(3.0-2.0*f);
      return mix(a,b,u.x) + (c-a)*u.y*(1.0-u.x) + (d-b)*u.x*u.y;
    }
    float fbm(vec2 p){
      float v = 0.0;
      float a = 0.55;
      for(int i=0;i<5;i++){
        v += a * noise(p);
        p *= 2.01;
        a *= 0.5;
      }
      return v;
    }

    vec4 open_color(vec3 coords_geo, vec3 size_geo){
      float t = niri_clamped_progress;
      vec2 uv = coords_geo.xy;

      // 前沿：从上到下
      float front = mix(1.08, -0.08, t);

      // 分段火柱：让火舌“根根分明”，不是整条大波浪
      float cols = 80.0;
      float colId = floor(uv.x * cols);
      float rnd = hash21(vec2(colId, niri_random_seed * 7.0));

      float xLocal = fract(uv.x * cols);               // 0..1 in a column
      float pillar = smoothstep(0.0, 0.18, xLocal) * (1.0 - smoothstep(0.82, 1.0, xLocal)); // 柱子中心更强
      pillar = mix(0.35, 1.0, pillar);

      // 多层噪声：小尺度细节为主，避免“大起伏”
      float nLow = fbm(vec2(uv.x*3.0, uv.y*6.0) + vec2(0.0, t*1.2) + rnd*3.0);
      float nMid = fbm(vec2(uv.x*10.0, uv.y*14.0) + vec2(rnd*2.0, t*4.0));
      float nHi  = fbm(vec2(uv.x*28.0, uv.y*40.0) + vec2(t*6.0, t*10.0));

      // 火舌高度：每列略不同（rnd），并且更多细碎细节（nHi）
      float height = (0.035 + 0.045*rnd) * pillar;
      float detail = (nHi - 0.5) * 0.030 + (nMid - 0.5) * 0.018 + (nLow - 0.5) * 0.010;

      // 燃烧线：burnLine < 0 => 已显示
      float burnLine = (front - uv.y) + height + detail;

      // 内容显现遮罩（这是“燃烧揭示”）
      float mask = 1.0 - smoothstep(0.00, 0.05, burnLine);

      // 关键：只在燃烧前沿附近画火，不做全屏
      float bandWidth = 0.09; // 火焰带宽（小一点，避免全屏感）
      float flameBand = 1.0 - smoothstep(0.00, bandWidth, abs(burnLine));

      // 只在火焰带附近做轻微扭曲（小幅，避免大波浪）
      float wob = (nHi - 0.5) * 0.012 * flameBand;
      vec2 sample_uv = uv + vec2(wob, -abs(wob) * 0.6);

      vec4 col = texture2D(niri_tex, (niri_geo_to_tex * vec3(sample_uv, 1.0)).xy);

      // 火焰着色：更亮、更丰富（核心更黄，外焰更橙红），但只作用于 flameBand
      float edge = smoothstep(0.06, 0.00, abs(burnLine));
      float coreMask = flameBand * (0.35 + 0.65*edge);

      vec3 rim  = vec3(1.05, 0.40, 0.10);
      vec3 core = vec3(1.35, 1.00, 0.35);

      // 火尖更亮：靠近 burnLine=0 的一侧增强
      float tip = smoothstep(0.06, -0.02, burnLine);
      vec3 flame = mix(rim, core, tip);

      // 少量“炭化边”：在火带外侧一点点压暗（仍然局部）
      vec3 char = vec3(0.10, 0.06, 0.05);
      float charBand = (1.0 - smoothstep(bandWidth, bandWidth*1.8, abs(burnLine))) * 0.15;

      col.rgb = mix(col.rgb, char, charBand);
      col.rgb = mix(col.rgb, flame, coreMask);

      col.a *= mask;
      return col;
    }
    "
  }

  window-close {
    duration-ms 210
    curve "ease-out-quad"
    custom-shader "
    float hash21(vec2 p){
      p = fract(p * vec2(123.34, 456.21));
      p += dot(p, p + 45.32);
      return fract(p.x * p.y);
    }
    float noise(vec2 p){
      vec2 i = floor(p);
      vec2 f = fract(p);
      float a = hash21(i);
      float b = hash21(i + vec2(1.0, 0.0));
      float c = hash21(i + vec2(0.0, 1.0));
      float d = hash21(i + vec2(1.0, 1.0));
      vec2 u = f*f*(3.0-2.0*f);
      return mix(a,b,u.x) + (c-a)*u.y*(1.0-u.x) + (d-b)*u.x*u.y;
    }
    float fbm(vec2 p){
      float v = 0.0;
      float a = 0.55;
      for(int i=0;i<5;i++){
        v += a * noise(p);
        p *= 2.01;
        a *= 0.5;
      }
      return v;
    }

    vec4 close_color(vec3 coords_geo, vec3 size_geo){
      float t = niri_clamped_progress;
      vec2 uv = coords_geo.xy;

      // 前沿：从下到上
      float front = mix(-0.08, 1.08, t);

      float cols = 80.0;
      float colId = floor(uv.x * cols);
      float rnd = hash21(vec2(colId, niri_random_seed * 9.0));

      float xLocal = fract(uv.x * cols);
      float pillar = smoothstep(0.0, 0.18, xLocal) * (1.0 - smoothstep(0.82, 1.0, xLocal));
      pillar = mix(0.35, 1.0, pillar);

      float nLow = fbm(vec2(uv.x*3.0, uv.y*6.0) + vec2(0.0, -t*1.3) + rnd*3.0);
      float nMid = fbm(vec2(uv.x*10.0, uv.y*14.0) + vec2(rnd*2.0, -t*4.5));
      float nHi  = fbm(vec2(uv.x*28.0, uv.y*40.0) + vec2(-t*6.5, -t*10.5));

      float height = (0.035 + 0.045*rnd) * pillar;
      float detail = (nHi - 0.5) * 0.030 + (nMid - 0.5) * 0.018 + (nLow - 0.5) * 0.010;

      // burnLine < 0 => 已烧掉
      float burnLine = (uv.y - front) + height + detail;

      float keep = smoothstep(0.00, 0.05, burnLine);

      float bandWidth = 0.09;
      float flameBand = 1.0 - smoothstep(0.00, bandWidth, abs(burnLine));

      float wob = (nHi - 0.5) * 0.012 * flameBand;
      vec2 sample_uv = uv + vec2(wob, abs(wob) * 0.6);

      vec4 col = texture2D(niri_tex, (niri_geo_to_tex * vec3(sample_uv, 1.0)).xy);

      float edge = smoothstep(0.06, 0.00, abs(burnLine));
      float coreMask = flameBand * (0.35 + 0.65*edge);

      vec3 rim  = vec3(1.00, 0.38, 0.10);
      vec3 core = vec3(1.30, 0.95, 0.33);

      float tip = smoothstep(0.06, -0.02, burnLine);
      vec3 flame = mix(rim, core, tip);

      vec3 char = vec3(0.10, 0.06, 0.05);
      float charBand = (1.0 - smoothstep(bandWidth, bandWidth*1.8, abs(burnLine))) * 0.15;

      col.rgb = mix(col.rgb, char, charBand);
      col.rgb = mix(col.rgb, flame, coreMask);

      col.a *= keep;
      return col;
    }
    "
  }

}
